<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="top.wjc.bookmallbackend.mapper.OrderItemMapper">

    <resultMap id="BaseResultMap" type="top.wjc.bookmallbackend.entity.OrderItem">
        <id property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="bookId" column="book_id"/>
        <result property="bookName" column="book_name"/>
        <result property="price" column="price"/>
        <result property="quantity" column="quantity"/>
        <result property="totalPrice" column="total_price"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, order_id, book_id, book_name, price, quantity, total_price
    </sql>

    <insert id="batchInsert">
        INSERT INTO order_item (order_id, book_id, book_name, price, quantity, total_price)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (#{item.orderId}, #{item.bookId}, #{item.bookName}, #{item.price}, #{item.quantity}, #{item.totalPrice})
        </foreach>
    </insert>

    <select id="selectByOrderId" resultType="top.wjc.bookmallbackend.vo.OrderItemVO">
        SELECT book_id, book_name, price, quantity, total_price
        FROM order_item
        WHERE order_id = #{orderId}
        ORDER BY id ASC
    </select>

</mapper>
